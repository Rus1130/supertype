{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "SuperType",
    "patterns": [
        { "include": "#comments" },
        { "include": "#markup" },
        { "include": "#header" },
        { "include": "#escapes" },
        { "include": "#tags" }
    ],
	"repository": {
        "colors": {
            "patterns": [
                {
                    "name": "color.st",
                    "match": "#(?:[0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})\\b"
                },
                {
                    "name": "color.st",
                    "match": "\\b(?:25[0-5]|2[0-4]\\d|1?\\d?\\d),(?:25[0-5]|2[0-4]\\d|1?\\d?\\d),(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)\\b"
                }
            ]
        },
        "tags": {
            "patterns": [
                {
                    "name": "tag.st",
                    "begin": "(?<!\\\\)\\[((?:removelast|custom|customremove|function|tab|gopage|color|bg|speed|speeddefault|newline|linebreak|sleep|glitch|instant))\\b",
                    "beginCaptures": {
                        "0": { "name": "tag.st" },
                        "1": { "name": "tag.st" }
                    },
                    "end": "(?<!\\\\)\\]",
                    "endCaptures": {
                        "0": { "name": "tag.st" }
                    },
                    "patterns": [
                        {
                            "name": "specific.st",
                            "match": "\\b(reset|override|default|keep|end|instant|separate)\\b"
                        },
                        { "include": "#strings" },
                        { "include": "#colors" },
                        {
                            "name": "constant.numeric.integer.st",
                            "match": "\\b\\d+\\b"
                        },
                        {
                            "name": "constant.language.boolean.st",
                            "match": "\\b(true|false)\\b"
                        },
                        {
                            "include": "#escapes"
                        }
                    ]
                }
            ]
        },
        "header": {
            "patterns": [
                {
                    "name": "meta.header.st",
                    "begin": "\\btypewriter\\s*:\\s*\\{",
                    "beginCaptures": {
                        "0": { "name": "keyword.control.header.st" }
                    },
                    "end": "\\}",
                    "endCaptures": {
                        "0": { "name": "keyword.control.header.st" }
                    },
                    "patterns": [
                        { "include": "#headerObject" }
                    ]
                }
            ]
        },
        "headerObject": {
            "patterns": [
                {
                    "begin": "\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "0": { "name": "keyword.control.header.st" }
                    },
                    "endCaptures": {
                        "0": { "name": "keyword.control.header.st" }
                    },
                    "patterns": [
                        { "include": "#headerObject" }
                    ]
                },
                {
                    "name": "support.type.property.st",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*:)"
                },
                { "include": "#strings" },
                { "include": "#colors" },
                {
                    "name": "constant.numeric.integer.st",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.language.boolean.st",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "markup": {
            "patterns": [
                {
                    "name": "style.bold.st",
                    "begin": "(?<!\\\\)\\*",
                    "beginCaptures": {
                        "0": {
                            "name": "comment.block.supertype"
                        }
                    },
                    "end": "(?<!\\\\)\\*",
                    "endCaptures": {
                        "0": {
                            "name": "comment.block.supertype"
                        }
                    },
                    "patterns": [
                        { "include": "#escapes" }
                    ]
                },
                {
                    "name": "style.italic.st",
                    "begin": "(?<!\\\\)/",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.italic.begin.supertype"
                        }
                    },
                    "end": "(?<!\\\\)/",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.italic.end.supertype"
                        }
                    },
                    "patterns": [
                        { "include": "#escapes" }
                    ]
                },
                {
                    "name": "style.underline.st",
                    "begin": "(?<!\\\\)_",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.underline.begin.supertype"
                        }
                    },
                    "end": "(?<!\\\\)_",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.underline.end.supertype"
                        }
                    },
                    "patterns": [
                        { "include": "#escapes" }
                    ]
                },
                {
                    "name": "style.strike.st",
                    "begin": "(?<!\\\\)-",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.strikethrough.begin.supertype"
                        }
                    },
                    "end": "(?<!\\\\)-",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.strikethrough.end.supertype"
                        }
                    },
                    "patterns": [
                        { "include": "#escapes" }
                    ]
                }
            ]
        },
        "escapes": {
            "patterns": [
                {
                    "name": "comment.block.supertype",
                    "match": "\\\\(?=.)"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.supertype",
                    "begin": "(?<!\\\\){{#",
                    "end": "(?<!\\\\)#}}"
                }
            ]
        },
		"strings": {
			"name": "string.quoted.double.supertype",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.supertype",
					"match": "\\\\(?=.)"
				}
			]
		}
	},
	"scopeName": "source.st"
}